# Optional: enable Gemini-based email generation.
# Copy this file to .env and add your Gemini API key.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model override. The script default is gemini-3-flash-preview.
# If your account has a different Flash model ID, set it here.
GEMINI_MODEL=gemini-3-flash-preview

# Optional: enable sending generated emails over SMTP.
# For Gmail, use an app password, not your normal Google password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=anshika.sharma.mailme@gmail.com
SMTP_PASSWORD=abcdefghijklmnop
SMTP_FROM_EMAIL=anshika.sharma.mailme@gmail.com
SMTP_FROM_NAME=Anshika
SMTP_REPLY_TO=anshika.sharma.mailme@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
